# ═══════════════════════════════════════════════
# ClawBot – Environment Configuration
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs that are allowed to control the bot
# Leave empty to allow ALL users (not recommended for public deployment)
# Find your user ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=123456789

# ── Ollama ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Model to use – must be pulled with `ollama pull <model>`
# Recommended free models:
#   deepseek-coder     (best for coding tasks, 6.7B)
#   deepseek-coder:33b (higher quality, needs 20GB+ RAM)
#   codellama          (Meta's code model)
#   llama3             (general purpose)
#   qwen2.5-coder      (excellent coder, fast)
OLLAMA_MODEL=deepseek-coder

# Request timeout in milliseconds (default: 2 minutes)
OLLAMA_TIMEOUT=120000

# Context window size
OLLAMA_CTX=8192

# Temperature (0.0 = deterministic, 1.0 = creative)
OLLAMA_TEMPERATURE=0.3

# ── Agent ─────────────────────────────────────────
# Directory where the agent creates/modifies project files
WORKSPACE_DIR=/Users/Prem/clawbot-workspace

# Maximum number of steps per task (safety limit)
MAX_STEPS=30

# Number of retry attempts on step failure
MAX_RETRIES=3

# Per-step timeout in milliseconds
STEP_TIMEOUT_MS=60000

# ── GitHub (optional) ────────────────────────────
# Personal access token for GitHub API (clone, commit, push, PR)
# Leave empty to use SSH keys or unauthenticated git
GITHUB_TOKEN=

GITHUB_DEFAULT_BRANCH=main

# ── Search ───────────────────────────────────────
# Max number of search results to return
SEARCH_MAX_RESULTS=5

# ── Logging ──────────────────────────────────────
LOG_DIR=./logs
LOG_LEVEL=info
